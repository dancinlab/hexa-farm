#!hexa strict
// tests/test_selftest.hexa — 18-verb spec-presence harness

fn main() {
    let root = env("HEXA_FARM_ROOT")
    let mut p = "cli/hexa-farm.hexa"
    if root.len() > 0 { p = root + "/cli/hexa-farm.hexa" }

    let raw = exec("HEXA_FARM_ROOT=" + root + " hexa run " + p + " selftest 2>&1")
    if raw.contains("__HEXA_FARM_SELFTEST__ PASS") == false {
        println("test_selftest: FAIL (sentinel missing)")
        println(raw.trim())
        exit(1)
    }
    if raw.contains("total verbs: 18") == false {
        println("test_selftest: FAIL (verb count != 18)")
        exit(1)
    }
    if raw.contains("present:     18/18") == false {
        println("test_selftest: FAIL (presence != 18/18)")
        exit(1)
    }
    println("test_selftest: PASS — 18/18 hexa-farm verb specs present")
}
